# ============================
# APP CONFIG
# ============================
APP_NAME=rag_backend
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ============================
# DATABASE (Postgres)
# ============================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rag_app
DATABASE_URL=postgresql+asyncpg://postgres:RednasR112@localhost:5432/fastapi_app5_2

# -----------------------------
# REDIS CONFIG
# -----------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# -----------------------------
# VECTOR INDEX CONFIG
# -----------------------------
REDIS_VECTOR_INDEX=vec_index
VECTOR_DIM=384


# ============================
# JWT / AUTH
# ============================
JWT_SECRET=superlongsecretkeythatismorethan32bytes123
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7


# ============================
# RAG / AI CONFIG
# ============================
EMBEDDING_MODEL=nomic-embed-text
LLM_MODEL=phi3:mini
VECTOR_DB=redis
CHUNK_SIZE=500
CHUNK_OVERLAP=50
